generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [postgis]
}

model User {
  id                   String   @id @default(cuid())
  name                 String?
  email                String?  @unique
  emailVerified        DateTime?
  image                String?
  city                 String?
  state                String?
  country              String?

  // Strava OAuth
  stravaAthleteId      Int?     @unique
  stravaAccessToken    String?
  stravaRefreshToken   String?
  stravaTokenExpires   DateTime?

  // Computed running aggregates
  averagePace          Float?   // min/km
  averageDistance       Float?   // km
  weeklyFrequency      Float?   // runs per week
  preferredDays        Int[]    // 0=Sun..6=Sat
  preferredTimeSlot    String?  // early_morning, morning, midday, evening, night

  // Profile
  gender               String?  // "man" | "woman" | "non_binary" | "prefer_not_to_say"
  genderMatchWith      String[] @default(["man", "woman", "non_binary"]) // genders user wants to match with

  // Sport & training profile
  sportRunning         Boolean  @default(false)
  sportCycling         Boolean  @default(false)
  longRunPace          Float?   // min/km (runners only)
  longRunDistance       Float?   // km (runners only)
  raceDistance         String?  // e.g. "5K", "10K", "Half Marathon", "Marathon", "Ultra"
  raceTargetTime       String?  // e.g. "1:45:00" (runners only)
  cyclingRoad          Boolean  @default(false)
  cyclingMountain      Boolean  @default(false)
  units                String   @default("metric") // "metric" | "imperial"

  // Deprecated (kept for migration, unused)
  sport                String?
  cyclingType          String?
  genderMatchPreference String  @default("any")

  // Notifications
  runNotifications     String   @default("my_zones") // "all_nearby" | "my_zones" | "custom_areas" | "none"
  notifyTimeStart      String?  // e.g. "05:00" - earliest departure time to notify about
  notifyTimeEnd        String?  // e.g. "20:00" - latest departure time to notify about

  // Onboarding (null until user completes the onboarding wizard)
  onboardedAt          DateTime?

  // Self-reported profile fields (used when no Strava data, e.g. Apple-only sign-in)
  selfReportedPace     Float?   // min/km
  selfReportedDistance Float?   // km (typical run length)
  selfReportedFrequency Float?  // runs per week
  hasStrava            Boolean  @default(false) // becomes true once Strava is connected

  // App Store compliance
  ageConfirmedAt       DateTime?  // user confirmed 17+ at signup
  safetyAckAt          DateTime?  // user acknowledged safety tips

  // Privacy
  isDiscoverable       Boolean  @default(false)
  locationPrecision    String   @default("neighborhood") // neighborhood, city, hidden
  shareSchedule        Boolean  @default(true)
  sharePace            Boolean  @default(true)

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  // Relations
  activities           Activity[]
  runningZones         RunningZone[]
  schedulePatterns     SchedulePattern[]
  searchPreferences    SearchPreferences?
  plannedRuns          PlannedRun[]
  plannedRunJoins      PlannedRunParticipant[]
  runInvitations       RunInvitation[]
  notificationAreas    NotificationArea[]
  clubMemberships      ClubMember[]
  threadMemberships    ThreadMember[]
  sentMessages         Message[]
  accounts             Account[]
  sessions             Session[]

  // Mutual connection (Facebook-style friend requests) relations
  connectionsSent      Connection[] @relation("ConnectionRequester")
  connectionsReceived  Connection[] @relation("ConnectionAddressee")

  // Races the user is signed up for
  races                UserRace[]

  // Moderation / compliance
  blocksGiven          Block[]    @relation("BlocksGiven")
  blocksReceived       Block[]    @relation("BlocksReceived")
  reportsFiled         Report[]   @relation("ReportsFiled")
  reportsAgainst       Report[]   @relation("ReportsAgainst")
}

/// One-way block. If A blocks B, A is hidden from B and vice versa in
/// discovery; messages between them are rejected; invitations are blocked.
model Block {
  id         String   @id @default(cuid())
  blockerId  String
  blockedId  String
  createdAt  DateTime @default(now())

  blocker User @relation("BlocksGiven", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("BlocksReceived", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockedId])
}

/// User-filed report for moderation review. App Store 1.2 requires UGC apps
/// to provide a reporting mechanism with response within 24h.
model Report {
  id              String   @id @default(cuid())
  reporterId      String
  targetUserId    String?
  targetMessageId String?
  targetRunId     String?
  reason          String   // harassment | spam | inappropriate | safety | impersonation | other
  details         String?
  status          String   @default("open") // open | reviewed | dismissed | actioned
  createdAt       DateTime @default(now())
  reviewedAt      DateTime?

  reporter   User  @relation("ReportsFiled", fields: [reporterId], references: [id], onDelete: Cascade)
  targetUser User? @relation("ReportsAgainst", fields: [targetUserId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([targetUserId])
  @@index([createdAt])
}

// Mutual connection (friend request) model
// When requester sends a request, status = "pending". The addressee can accept or decline.
// Once accepted, both users are "in each other's corillo" and can message.
model Connection {
  id          String   @id @default(cuid())
  requesterId String
  addresseeId String
  status      String   @default("pending") // "pending" | "accepted" | "declined"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  requester User @relation("ConnectionRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee User @relation("ConnectionAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)

  @@unique([requesterId, addresseeId])
  @@index([addresseeId, status])
  @@index([requesterId, status])
}

// Races an athlete is signed up to participate in.
// Used both as profile information and as a discovery filter.
model UserRace {
  id         String    @id @default(cuid())
  userId     String
  name       String    // user-entered race name, e.g. "Boston Marathon 2026"
  distance   String?   // "5K" | "10K" | "Half Marathon" | "Marathon" | "Ultra" | "Other"
  raceDate   DateTime? // scheduled race date
  targetTime String?   // e.g. "3:45:00"
  city       String?   // e.g. "Boston, MA"
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([name])
}

// Auth.js required models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Activity {
  id                String   @id @default(cuid())
  userId            String
  stravaActivityId  BigInt   @unique
  sportType         String   // Run, TrailRun, etc.
  name              String?
  startDate         DateTime
  elapsedTime       Int      // seconds
  movingTime        Int?     // seconds
  distance          Float    // meters
  averageSpeed      Float?   // m/s
  startLatitude     Float?
  startLongitude    Float?
  endLatitude       Float?
  endLongitude      Float?
  dayOfWeek         Int      // 0=Sun..6=Sat
  timeSlot          String   // early_morning, morning, midday, evening, night
  isHidden          Boolean  @default(false)

  // PostGIS geometry - populated by DB trigger
  startPoint        Unsupported("geometry(Point,4326)")?

  createdAt         DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([startDate])
}

model RunningZone {
  id             String @id @default(cuid())
  userId         String
  latitude       Float  // fuzzed center
  longitude      Float  // fuzzed center
  activityCount  Int
  radius         Float  // meters
  label          String?

  // PostGIS geometry - populated by DB trigger
  center         Unsupported("geometry(Point,4326)")?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model SchedulePattern {
  id        String @id @default(cuid())
  userId    String
  dayOfWeek Int    // 0=Sun..6=Sat
  timeSlot  String // early_morning, morning, midday, evening, night
  frequency Float  // 0.0-1.0: fraction of weeks

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dayOfWeek, timeSlot])
}

model SearchPreferences {
  id                 String   @id @default(cuid())
  userId             String   @unique
  maxDistanceKm      Float    @default(10)
  preferredDays      Int[]    // 0=Sun..6=Sat, empty = any
  preferredTimeSlots String[] // empty = any
  minPace            Float    @default(3.0)  // min/km
  maxPace            Float    @default(10.0) // min/km
  minDistance         Float    @default(1.0)  // km
  maxDistance         Float    @default(50.0) // km

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PlannedRun {
  id               String   @id @default(cuid())
  creatorId        String
  activityType     String   @default("run") // "run" | "ride"
  title            String
  description      String?
  scheduledAt      DateTime
  estimatedPace    Float?   // min/km (for runs)
  estimatedSpeed   Float?   // km/h (for rides)
  estimatedDistance Float?  // km
  terrainType      String?  // "road" | "mountain" | "gravel" (for rides)
  latitude         Float
  longitude        Float
  locationName     String?
  maxParticipants  Int      @default(10)
  genderRestriction String? // null = open to all, "man" | "woman" | "non_binary"
  clubId           String?  // null = not club-associated
  clubOnly         Boolean  @default(false) // if true, only club members can join

  // Recurring activities: one single row represents the whole series.
  // `scheduledAt` is the series start; `recurrence` drives future occurrences
  // that are computed on the fly (no child rows).
  recurrence       String?  // "weekly" | "biweekly" | "monthly"
  recurrenceEndAt  DateTime?

  // Per-activity chat — shared for the whole series so it persists across occurrences
  threadId         String?  @unique

  // PostGIS geometry - populated by DB trigger
  meetingPoint     Unsupported("geometry(Point,4326)")?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  creator      User                    @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  club         Club?                   @relation(fields: [clubId], references: [id])
  participants PlannedRunParticipant[]
  invitations  RunInvitation[]

  thread       Thread? @relation("PlannedRunThread", fields: [threadId], references: [id])

  @@index([scheduledAt])
  @@index([creatorId])
  @@index([clubId])
}

model PlannedRunParticipant {
  id       String   @id @default(cuid())
  runId    String
  userId   String
  response String   @default("going") // "going" | "maybe"
  joinedAt DateTime @default(now())

  run  PlannedRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([runId, userId])
}

model NotificationArea {
  id        String @id @default(cuid())
  userId    String
  label     String  // user-entered: town, neighborhood, zip code, etc.
  latitude  Float?  // geocoded center (optional, for distance matching)
  longitude Float?  // geocoded center (optional, for distance matching)
  radiusKm  Float   @default(10) // notification radius
  polygon   Json?   // GeoJSON polygon coordinates [[lng,lat], ...] for drawn areas
  isPolygon Boolean @default(false) // true if area is defined by a drawn polygon

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Club {
  id               String   @id @default(cuid())
  stravaClubId     Int      @unique
  name             String
  description      String?
  sportType        String?  // "running" | "cycling" | "other"
  city             String?
  state            String?
  country          String?
  memberCount      Int      @default(0)
  profileImage     String?  // URL from Strava
  coverImage       String?  // URL from Strava

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  members          ClubMember[]
  plannedRuns      PlannedRun[]
}

model ClubMember {
  id        String   @id @default(cuid())
  clubId    String
  userId    String
  role      String   @default("member") // "member" | "admin"
  joinedAt  DateTime @default(now())

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clubId, userId])
  @@index([userId])
}

model RunInvitation {
  id        String   @id @default(cuid())
  runId     String
  userId    String
  status    String   @default("pending") // "pending" | "accepted" | "declined"
  createdAt DateTime @default(now())

  run  PlannedRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([runId, userId])
  @@index([userId, status])
}

model Thread {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // When set, this thread belongs to a planned activity (the root run for a series).
  // Membership in this thread is the only authorization needed; areConnected() is bypassed.
  activityRunId String?

  members      ThreadMember[]
  messages     Message[]
  activityRun  PlannedRun?    @relation("PlannedRunThread")

  @@index([activityRunId])
}

model ThreadMember {
  id         String    @id @default(cuid())
  threadId   String
  userId     String
  lastReadAt DateTime?

  thread Thread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([threadId, userId])
}

model Message {
  id        String   @id @default(cuid())
  threadId  String
  senderId  String
  content   String
  createdAt DateTime @default(now())

  thread Thread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender User   @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
}
